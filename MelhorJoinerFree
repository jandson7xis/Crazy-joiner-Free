local brainrots = {
"Garama","Dragon","Elefante de Morango","Meow","La Secret","La Suprema",
"Chilin Chilin","La Taco Combinação","Orcaledon","Dragon Gingerini",
"Grifin","Lucky Block Secret","Antônio","Dug Dug","Senhore Carapate",
"Esok Sekolah","La Lucky Combinação","La Romântica","Popcuro and Fizzuro",
"Skibid Toilet","Hydra Dragon Canelone","Cavaleiro sem cabeça",
"Cloverat Clapat","Money Money","Puggy","Cerberus","Los Amigos",
"Claunito","Fishito","Celestial Pegasus"
}

local usados = {}

local function pegar()
    if #usados >= #brainrots then usados = {} end
    local escolha
    repeat
        escolha = brainrots[math.random(1,#brainrots)]
    until not table.find(usados, escolha)
    table.insert(usados, escolha)
    return escolha
end

local especiais = {
["Elefante de Morango"]=true,
["Meow"]=true,
["Skibid Toilet"]=true
}

local function valor()
    local v = math.random(300,5000)
    return v >= 1000 and string.format("%.1fB",v/1000) or v.."M"
end

local function hop()
    TeleportService:Teleport(game.PlaceId, player)
end

notif1.MouseButton1Click:Connect(hop)
notif2.MouseButton1Click:Connect(hop)

