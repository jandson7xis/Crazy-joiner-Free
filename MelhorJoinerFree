-- 🔁 LOOP
--------------------------------------------------
task.spawn(function()
    while true do
        for _,n in pairs({notif1,notif2}) do
            local nome = pegar()
            local val = valor()

            n.Text = "🚨 "..nome.." - "..val
            n.Visible = true

            if especiais[nome] then
                n.BackgroundColor3 = Color3.fromRGB(220,60,60)
                alert:Play()
            else
                n.BackgroundColor3 = Color3.fromRGB(90,90,90)
                normal:Play()
            end
        end

        wait(10)
        notif1.Visible = false
        notif2.Visible = false
        wait(2)
    end
end)
